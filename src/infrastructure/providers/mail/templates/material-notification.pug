doctype html
html
  head
    title Novo material
  body(style="font-family: Arial, sans-serif; padding: 20px;")
    h1(style="color: #333;") Novo material disponível
    p Olá#{name ? ' ' + name : ''},
    p Foi publicado um novo material na plataforma:
    p
      strong #{materialName}
    if materialLink
      p
        a(href=materialLink, style="color: #0066cc;") Acessar material
    p Acesse a plataforma para visualizar o conteúdo.
