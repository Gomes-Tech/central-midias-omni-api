// ============================================================
// CMO — Central de Mídia Omni
// Schema DBML (dbdiagram.io) — espelho do prisma/schema.prisma
// PostgreSQL via Prisma (@map = nome físico da coluna/tabela)
// ============================================================

// ============================================================
// MULTI-TENANT (base para FKs)
// ============================================================

Table organizations {
  id text [pk]
  name text [not null]
  slug text [not null, unique]
  domain text [unique]
  should_attach_users_by_domain boolean [not null, default: false]
  avatar_url text
  is_active boolean [not null, default: true]
  is_deleted boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null]
  deleted_at timestamp
}

// ============================================================
// RBAC (GLOBAL)
// ============================================================

Table roles {
  id text [pk]
  name text [not null, unique]
  label text [not null]
  is_system boolean [not null, default: false]
  can_access_backoffice boolean [not null, default: false]
  can_have_subordinates boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null]
  deleted_at timestamp
}

Table modules {
  id text [pk]
  name text [not null, unique]
  label text [not null]
}

Enum Action {
  CREATE
  READ
  UPDATE
  DELETE
}

Table role_permissions {
  id text [pk]
  role_id text [not null, ref: > roles.id]
  module_id text [not null, ref: > modules.id]
  action Action [not null]

  indexes {
    (role_id, module_id, action) [unique]
    module_id
  }
}

// ============================================================
// USUÁRIOS
// ============================================================

Table users {
  id text [pk]
  name text [not null]
  email text [not null, unique]
  password text [not null]
  tax_identifier text [not null, unique]
  phone text
  social_reason text
  avatar_url text
  birth_date timestamp
  admission_date timestamp
  is_first_access boolean [not null, default: true]
  is_active boolean [not null, default: true]
  is_deleted boolean [not null, default: false]
  deleted_at timestamp
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null]
  global_role_id text [ref: > roles.id]

  indexes {
    email
  }
}

Table user_hierarchies {
  id text [pk]
  manager_id text [not null, ref: > users.id]
  subordinate_id text [not null, ref: > users.id]
  organization_id text [not null, ref: > organizations.id]
  created_at timestamp [not null, default: `now()`]

  indexes {
    (subordinate_id, organization_id) [unique]
    (manager_id, organization_id)
  }
}

// Colunas sem @map no Prisma permanecem em camelCase no PostgreSQL
Table password_reset_tokens {
  id text [pk]
  token text [not null, unique]
  email text [not null]
  used boolean [not null, default: false]
  expires_at timestamp [not null]
  "createdAt" timestamp [not null, default: `now()`]
}

Table members {
  id text [pk]
  organization_id text [not null, ref: > organizations.id]
  user_id text [not null, ref: > users.id]
  role_id text [not null, ref: > roles.id]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null]

  indexes {
    (organization_id, user_id) [unique]
  }
}

// ============================================================
// CATEGORIAS (MENU HIERÁRQUICO)
// ============================================================

Table categories {
  id text [pk]
  organization_id text [not null, ref: > organizations.id]
  name text [not null]
  slug text [not null]
  is_active boolean [not null, default: true]
  "order" int [not null]
  "parentId" text [ref: > categories.id]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null]
  is_deleted boolean [not null, default: false]
  deleted_at timestamp

  indexes {
    (organization_id, slug) [unique]
    (organization_id, "order") [unique]
    organization_id
    "parentId"
    (organization_id, "parentId")
  }
}

// ============================================================
// ACESSO ÀS CATEGORIAS POR PAPEL
// ============================================================

Table category_role_accesses {
  id text [pk]
  category_id text [not null, ref: > categories.id]
  role_id text [not null, ref: > roles.id]
  organization_id text [not null, ref: > organizations.id]

  indexes {
    (category_id, role_id, organization_id) [unique]
    (role_id, organization_id)
    category_id
  }
}

// ============================================================
// BANNERS
// ============================================================

Table banners {
  id text [pk]
  organization_id text [not null, ref: > organizations.id]
  mobile_image_url text [not null]
  desktop_image_url text [not null]
  name text [not null]
  link text
  "order" int [not null]
  is_active boolean [not null, default: true]
  initial_date timestamp
  finish_date timestamp
  is_deleted boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null]
  deleted_at timestamp

  indexes {
    organization_id
  }
}

// ============================================================
// LOG
// ============================================================

Enum LogLevel {
  INFO
  WARNING
  ERROR
}

Table logs {
  id text [pk]
  level LogLevel [not null]
  message text [not null]
  context jsonb
  request_id text
  path text
  method text
  user_id text
  created_at timestamp [not null, default: `now()`]
}

Table seed_status {
  id text [pk]
  executed_at timestamp [not null, default: `now()`]
}
