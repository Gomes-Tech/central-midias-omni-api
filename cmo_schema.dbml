// ============================================================
// CMO — Central de Mídia Omni
// Schema DBML para dbdiagram.io
// ============================================================

// ============================================================
// DOMÍNIO 1 — MULTI-TENANCY
// ============================================================

Table companies {
  id            uuid        [pk, default: `gen_random_uuid()`]
  name          varchar(100) [not null]
  slug          varchar(50)  [not null, unique]
  logo_url      text
  is_active     boolean      [not null, default: true]
  created_at    timestamp    [not null, default: `now()`]
  updated_at    timestamp    [not null, default: `now()`]

  indexes {
    slug [unique]
  }
}

// ============================================================
// DOMÍNIO 2 — USUÁRIOS E HIERARQUIA
// ============================================================

Table users {
  id              uuid        [pk, default: `gen_random_uuid()`]
  cpf_cnpj        varchar(18) [not null, unique]
  email           varchar(255) [not null, unique]
  phone           varchar(20)
  name            varchar(150) [not null]
  company_name    varchar(200)
  password_hash   text        [not null]
  avatar_url      text
  role            user_role   [not null]
  is_active       boolean     [not null, default: true]
  boss_id         uuid        [ref: > users.id]
  created_at      timestamp   [not null, default: `now()`]
  updated_at      timestamp   [not null, default: `now()`]
  last_login_at   timestamp

  indexes {
    cpf_cnpj [unique]
    email    [unique]
    boss_id
    role
  }
}

// Enum de roles do usuário (hierarquia definida no slide 2)
Enum user_role {
  ADMIN
  COLLABORATOR
  OWN_DIRECT_CHANNEL
  AGENT_DIRECT_CHANNEL
  SMALL_MASTER_AGENT
  MEDIUM_MASTER_AGENT
  LARGE_MASTER_AGENT
  PARTNER
  AGENT_EMPLOYEE
}

// Tabela pivô: usuário pode ter acesso a múltiplas empresas
Table user_company_accesses {
  id          uuid      [pk, default: `gen_random_uuid()`]
  user_id     uuid      [not null, ref: > users.id]
  company_id  uuid      [not null, ref: > companies.id]
  is_active   boolean   [not null, default: true]
  granted_at  timestamp [not null, default: `now()`]

  indexes {
    (user_id, company_id) [unique]
    user_id
    company_id
  }
}

// ============================================================
// DOMÍNIO 3 — MENU DINÂMICO (seções e subseções)
// ============================================================

Table menu_sections {
  id            uuid        [pk, default: `gen_random_uuid()`]
  company_id    uuid        [not null, ref: > companies.id]
  parent_id     uuid        [ref: > menu_sections.id]
  name          varchar(100) [not null]
  slug          varchar(100) [not null]
  description   text
  icon_url      text
  display_order int         [not null, default: 0]
  is_visible    boolean     [not null, default: true]
  is_active     boolean     [not null, default: true]
  allowed_roles user_role[] // array de roles permitidos para ver esta seção
  created_by    uuid        [ref: > users.id]
  created_at    timestamp   [not null, default: `now()`]
  updated_at    timestamp   [not null, default: `now()`]

  indexes {
    company_id
    parent_id
    (company_id, slug) [unique]
  }
}

// ============================================================
// DOMÍNIO 4 — MATERIAIS / ASSETS
// ============================================================

Table materials {
  id               uuid          [pk, default: `gen_random_uuid()`]
  company_id       uuid          [not null, ref: > companies.id]
  section_id       uuid          [ref: > menu_sections.id]
  title            varchar(255)  [not null]
  description      text
  file_url         text          [not null]
  file_type        file_type     [not null]
  file_size_bytes  bigint
  thumbnail_url    text
  region_scope     region_scope  [not null, default: 'ALL']
  is_personalizable boolean      [not null, default: false]
  is_active        boolean       [not null, default: true]
  scheduled_at     timestamp
  published_at     timestamp
  expires_at       timestamp
  created_by       uuid          [not null, ref: > users.id]
  created_at       timestamp     [not null, default: `now()`]
  updated_at       timestamp     [not null, default: `now()`]

  indexes {
    company_id
    section_id
    file_type
    region_scope
    published_at
    created_by
  }
}

Enum file_type {
  IMAGE
  PDF
  WORD
  EXCEL
  PPT
  VIDEO
  AUDIO
  EPS
  OTHER
}

Enum region_scope {
  ALL
  NORTE
  NORDESTE
  CENTRO_OESTE
  SUDESTE
  SUL
}

// ============================================================
// DOMÍNIO 5 — TAGUEAMENTO E BUSCA
// ============================================================

Table tags {
  id          uuid        [pk, default: `gen_random_uuid()`]
  company_id  uuid        [not null, ref: > companies.id]
  name        varchar(80) [not null]
  slug        varchar(80) [not null]
  created_at  timestamp   [not null, default: `now()`]

  indexes {
    (company_id, slug) [unique]
  }
}

Table material_tags {
  material_id uuid [not null, ref: > materials.id]
  tag_id      uuid [not null, ref: > tags.id]

  indexes {
    (material_id, tag_id) [pk]
    tag_id
  }
}

// ============================================================
// DOMÍNIO 6 — MÉTRICAS E INTERAÇÕES
// ============================================================

Table material_views {
  id          uuid      [pk, default: `gen_random_uuid()`]
  material_id uuid      [not null, ref: > materials.id]
  user_id     uuid      [not null, ref: > users.id]
  viewed_at   timestamp [not null, default: `now()`]

  indexes {
    material_id
    user_id
    viewed_at
  }
}

Table material_downloads {
  id          uuid      [pk, default: `gen_random_uuid()`]
  material_id uuid      [not null, ref: > materials.id]
  user_id     uuid      [not null, ref: > users.id]
  downloaded_at timestamp [not null, default: `now()`]

  indexes {
    material_id
    user_id
    downloaded_at
  }
}

// ============================================================
// DOMÍNIO 7 — COMUNICADOS / DOCUMENTOS
// ============================================================

Table document_categories {
  id          uuid        [pk, default: `gen_random_uuid()`]
  company_id  uuid        [not null, ref: > companies.id]
  name        varchar(100) [not null]
  description text
  display_order int       [not null, default: 0]
  is_active   boolean     [not null, default: true]
  created_at  timestamp   [not null, default: `now()`]

  indexes {
    company_id
  }
}

Table documents {
  id                  uuid      [pk, default: `gen_random_uuid()`]
  company_id          uuid      [not null, ref: > companies.id]
  category_id         uuid      [ref: > document_categories.id]
  title               varchar(255) [not null]
  content             text
  file_url            text
  requires_acceptance boolean   [not null, default: false]
  is_active           boolean   [not null, default: true]
  scheduled_at        timestamp
  published_at        timestamp
  expires_at          timestamp
  created_by          uuid      [not null, ref: > users.id]
  created_at          timestamp [not null, default: `now()`]
  updated_at          timestamp [not null, default: `now()`]

  indexes {
    company_id
    category_id
    published_at
    created_by
  }
}

// Confirmação de leitura/aceite de documentos
Table document_read_receipts {
  id          uuid      [pk, default: `gen_random_uuid()`]
  document_id uuid      [not null, ref: > documents.id]
  user_id     uuid      [not null, ref: > users.id]
  read_at     timestamp [not null, default: `now()`]
  accepted    boolean   [not null, default: false]
  accepted_at timestamp

  indexes {
    (document_id, user_id) [unique]
    document_id
    user_id
  }
}

// ============================================================
// DOMÍNIO 8 — BANNERS
// ============================================================

Table banners {
  id          uuid      [pk, default: `gen_random_uuid()`]
  company_id  uuid      [not null, ref: > companies.id]
  image_url   text      [not null]
  link_url    text
  title       varchar(200)
  display_order int     [not null, default: 0]
  starts_at   timestamp
  ends_at     timestamp
  is_active   boolean   [not null, default: true]
  created_by  uuid      [not null, ref: > users.id]
  created_at  timestamp [not null, default: `now()`]
  updated_at  timestamp [not null, default: `now()`]

  indexes {
    company_id
    is_active
    starts_at
    ends_at
  }
}

// ============================================================
// DOMÍNIO 9 — CALENDÁRIO EDITORIAL (Fase 3)
// ============================================================

Table calendar_events {
  id          uuid      [pk, default: `gen_random_uuid()`]
  company_id  uuid      [not null, ref: > companies.id]
  material_id uuid      [ref: > materials.id]
  title       varchar(200) [not null]
  description text
  event_date  date      [not null]
  event_type  varchar(50)
  created_by  uuid      [not null, ref: > users.id]
  created_at  timestamp [not null, default: `now()`]
  updated_at  timestamp [not null, default: `now()`]

  indexes {
    company_id
    event_date
    material_id
  }
}

// ============================================================
// DOMÍNIO 10 — PEÇAS PERSONALIZÁVEIS (Fase 3)
// ============================================================

Table personalizable_fields {
  id          uuid        [pk, default: `gen_random_uuid()`]
  material_id uuid        [not null, ref: > materials.id]
  field_key   varchar(80) [not null]  // ex: 'agent_name', 'phone', 'city', 'event_date'
  label       varchar(100) [not null]
  field_type  varchar(30) [not null]  // 'text', 'date', 'phone', 'image'
  is_required boolean     [not null, default: false]
  display_order int       [not null, default: 0]

  indexes {
    material_id
    (material_id, field_key) [unique]
  }
}

// ============================================================
// DOMÍNIO 11 — BRINDES
// ============================================================

Table gifts {
  id              uuid      [pk, default: `gen_random_uuid()`]
  company_id      uuid      [not null, ref: > companies.id]
  section_id      uuid      [ref: > menu_sections.id]
  name            varchar(200) [not null]
  description     text
  art_file_url    text      [not null]
  thumbnail_url   text
  boutique_url    text      // link para a CNLOG/ecommerce
  is_active       boolean   [not null, default: true]
  created_by      uuid      [not null, ref: > users.id]
  created_at      timestamp [not null, default: `now()`]

  indexes {
    company_id
  }
}

// Registro de download de arte de brinde (gera aviso p/ mkt)
Table gift_download_requests {
  id          uuid      [pk, default: `gen_random_uuid()`]
  gift_id     uuid      [not null, ref: > gifts.id]
  user_id     uuid      [not null, ref: > users.id]
  status      varchar(30) [not null, default: 'PENDING'] // PENDING | APPROVED | REJECTED
  requested_at timestamp [not null, default: `now()`]
  reviewed_at  timestamp
  reviewed_by  uuid      [ref: > users.id]
  notes        text

  indexes {
    gift_id
    user_id
    status
  }
}

// ============================================================
// DOMÍNIO 12 — FAQ
// ============================================================

Table faq_items {
  id          uuid      [pk, default: `gen_random_uuid()`]
  company_id  uuid      [not null, ref: > companies.id]
  question    text      [not null]
  answer      text      [not null]
  display_order int     [not null, default: 0]
  is_active   boolean   [not null, default: true]
  created_by  uuid      [not null, ref: > users.id]
  created_at  timestamp [not null, default: `now()`]
  updated_at  timestamp [not null, default: `now()`]

  indexes {
    company_id
  }
}

// ============================================================
// DOMÍNIO 13 — NOTIFICAÇÕES / EMAILS
// ============================================================

Table notifications {
  id          uuid      [pk, default: `gen_random_uuid()`]
  company_id  uuid      [not null, ref: > companies.id]
  user_id     uuid      [not null, ref: > users.id]
  type        notification_type [not null]
  title       varchar(200) [not null]
  body        text
  reference_id uuid     // id do material/documento relacionado (polimórfico)
  reference_type varchar(50) // 'material' | 'document' | 'banner'
  is_read     boolean   [not null, default: false]
  sent_at     timestamp [not null, default: `now()`]
  read_at     timestamp

  indexes {
    user_id
    company_id
    type
    is_read
    sent_at
  }
}

Enum notification_type {
  WELCOME
  PASSWORD_RESET
  NEW_MATERIAL
  NEW_DOCUMENT
  DOCUMENT_ACCEPTANCE_REQUIRED
  BRINDE_REQUEST_APPROVED
  BRINDE_REQUEST_REJECTED
  BIRTHDAY_REMINDER
  CAMPAIGN_ALERT
}

// ============================================================
// DOMÍNIO 14 — BUSCA / AUDITORIA DE BUSCAS
// ============================================================

Table search_logs {
  id          uuid      [pk, default: `gen_random_uuid()`]
  company_id  uuid      [not null, ref: > companies.id]
  user_id     uuid      [not null, ref: > users.id]
  query       varchar(500) [not null]
  results_count int     [not null, default: 0]
  searched_at timestamp [not null, default: `now()`]

  indexes {
    company_id
    user_id
    searched_at
    query
  }
}

// ============================================================
// DOMÍNIO 15 — TOKENS DE AUTENTICAÇÃO
// ============================================================

Table password_reset_tokens {
  id          uuid      [pk, default: `gen_random_uuid()`]
  user_id     uuid      [not null, ref: > users.id]
  token_hash  text      [not null]
  expires_at  timestamp [not null]
  used_at     timestamp
  created_at  timestamp [not null, default: `now()`]

  indexes {
    user_id
    token_hash
    expires_at
  }
}
