generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  isActive  Boolean   @default(true) @map("is_active")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  platformUserRoles PlatformUserRole[]
  // createdCategories Category[] @relation("CategoryCreatedBy")
  // updatedCategories Category[] @relation("CategoryUpdatedBy")
  // deletedCategories Category[] @relation("CategoryDeletedBy")

  @@index([email])
  @@map("users")
}

// ============================================================
// MUNDO 1: PLATAFORMA (Admin Backoffice)
// Controla quem acessa o painel admin e o que pode fazer
// ============================================================

// Roles da plataforma: SUPER_ADMIN, MARKETING, REPORTS, etc.
model PlatformRole {
  id          String  @id @default(uuid())
  name        String  @unique // "SUPER_ADMIN", "MARKETING", "REPORTS_VIEWER"
  label       String           // "Super Administrador", "Marketing"
  isSystem    Boolean @default(false) @map("is_system") // roles protegidas (seed)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  platformUserRoles    PlatformUserRole[]
  platformRolePermissions PlatformRolePermission[]

  @@map("platform_roles")
}

// Quais permissões cada role admin tem
// Permissões são granulares por recurso + ação
model PlatformPermission {
  id       String @id @default(uuid())
  resource String // "materials", "reports", "companies", "categories", "users"
  action   String // "create", "read", "update", "delete", "publish"
  label    String

  platformRolePermissions PlatformRolePermission[]

  @@unique([resource, action])
  @@map("platform_permissions")
}

model PlatformRolePermission {
  id           String @id @default(uuid())
  platformRoleId       String @map("platform_role_id")
  platformPermissionId String @map("platform_permission_id")

  platformRole       PlatformRole       @relation(fields: [platformRoleId], references: [id])
  platformPermission PlatformPermission @relation(fields: [platformPermissionId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([platformRoleId, platformPermissionId])
  @@map("platform_role_permissions")
}

// Vínculo usuário ↔ role na plataforma (backoffice)
model PlatformUserRole {
  id             String @id @default(uuid())
  userId         String @map("user_id")
  platformRoleId String @map("platform_role_id")

  user         User         @relation(fields: [userId], references: [id])
  platformRole PlatformRole @relation(fields: [platformRoleId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, platformRoleId])
  @@map("platform_user_roles")
}


model Company {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  logoUrl  String? @map("logo_url")
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // tenantMemberships   TenantMembership[]
  // tenantRoles         TenantRole[]
  // tenantRoleHierarchies TenantRoleHierarchy[] // ← adicionado
  // categories          Category[]

  @@map("companies")
}

model Log {
  id        String   @id @default(uuid())
  level     LogLevel
  message   String   @map("message")
  context   Json?    @map("context")
  requestId String?  @map("request_id")
  path      String?  @map("path")
  method    String?  @map("method")
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("logs")
}

enum LogLevel {
  INFO
  WARNING
  ERROR
}
