generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  name          String
  socialReason  String   @map("social_reason")
  taxIdentifier String   @unique @map("tax_identifier")
  phone         String   @map("phone")
  birthDate     DateTime @map("birth_date")
  email         String   @unique
  password      String
  role          UserRole
  isActive      Boolean  @default(true) @map("is_active")
  isDeleted     Boolean  @default(false) @map("is_deleted")

  boss         User?   @relation("UserBoss", fields: [bossId], references: [id])
  subordinates User[]  @relation("UserBoss")
  bossId       String? @map("boss_id")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? @map("deleted_at")

  @@map("users")
}

enum UserRole {
  ADMIN
  COLLABORATOR
  OWN_DIRECT_CHANNEL
  AGENT_DIRECT_CHANNEL
  SMALL_MASTER_AGENT
  MEDIUM_MASTER_AGENT
  LARGE_MASTER_AGENT
  PARTNER
  AGENT_EMPLOYEE
}
