generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  isActive  Boolean   @default(true) @map("is_active")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  platformRoleId String   @map("platform_role_id")
  platformRole          PlatformRole         @relation(fields: [platformRoleId], references: [id])
  platformUserCompanies PlatformUserCompany[] // ← adicionado

  @@index([email])
  @@map("users")
}

// ============================================================
// MUNDO 1: PLATAFORMA (Admin Backoffice)
// Controla quem acessa o painel admin e o que pode fazer
// ============================================================

// Roles da plataforma: SUPER_ADMIN, MARKETING, REPORTS, etc.
// Todas as roles são globais — a role define O QUE pode fazer
// A PlatformUserCompany define ONDE (em quais companies) o usuário pode atuar
model PlatformRole {
  id        String    @id @default(uuid())
  name      String    @unique // "ADMIN", "MARKETING", "REPORTS", "CADASTRO"
  label     String            // "Administrador", "Marketing"
  isSystem  Boolean   @default(false) @map("is_system") // roles protegidas (seed)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users                   User[]
  platformRolePermissions PlatformRolePermission[]

  @@map("platform_roles")
}

// Permissões granulares por recurso + ação
model PlatformPermission {
  id       String @id @default(uuid())
  resource String // "materials", "reports", "companies", "categories", "users"
  action   String // "create", "read", "update", "delete", "publish"
  label    String

  platformRolePermissions PlatformRolePermission[]

  @@unique([resource, action])
  @@map("platform_permissions")
}

model PlatformRolePermission {
  id                   String @id @default(uuid())
  platformRoleId       String @map("platform_role_id")
  platformPermissionId String @map("platform_permission_id")

  platformRole       PlatformRole       @relation(fields: [platformRoleId], references: [id])
  platformPermission PlatformPermission @relation(fields: [platformPermissionId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([platformRoleId, platformPermissionId])
  @@map("platform_role_permissions")
}

// Vínculo usuário ↔ company no backoffice
// Define ONDE o usuário pode atuar (em quais companies)
// Regras de population:
//   - Usuários ADMIN → vinculados automaticamente via código ao criar uma nova company
//   - Demais roles   → vinculados manualmente por um admin
model PlatformUserCompany {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  organizationId String @map("organization_id")

  user    User    @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, organizationId])
  @@map("platform_user_companies")
}

model Organization {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  logoUrl  String? @map("logo_url")
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  platformUserCompanies PlatformUserCompany[] // ← adicionado

  // tenantMemberships     TenantMembership[]
  // tenantRoles           TenantRole[]
  // tenantRoleHierarchies TenantRoleHierarchy[]
  categories            Category[]

  @@map("organizations")
}

model Category {
  id        String  @id @default(cuid())
  organizationId String  @map("organization_id")
  name      String
  slug      String
  isActive  Boolean @default(true) @map("is_active")
  order     Int

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  organization Organization @relation(fields: [organizationId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  // categoryPermissions CategoryPermission[]

  @@unique([organizationId, slug])
  @@unique([organizationId, order])
  @@index([organizationId])
  @@index([parentId])
  @@map("categories")
}

model Log {
  id        String   @id @default(uuid())
  level     LogLevel
  message   String   @map("message")
  context   Json?    @map("context")
  requestId String?  @map("request_id")
  path      String?  @map("path")
  method    String?  @map("method")
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("logs")
}

enum LogLevel {
  INFO
  WARNING
  ERROR
}
