generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  avatarUrl String?   @map("avatar_url")
  isActive  Boolean   @default(true) @map("is_active")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  managedUsers UserHierarchy[] @relation("ManagerRelation")
  managerOf    UserHierarchy[] @relation("SubordinateRelation")
  members      Member[]

  @@index([email])
  @@map("users")
}

model UserHierarchy {
  id String @id @default(uuid())

  managerId      String @map("manager_id")
  subordinateId  String @map("subordinate_id")
  organizationId String @map("organization_id")

  manager      User         @relation("ManagerRelation", fields: [managerId], references: [id])
  subordinate  User         @relation("SubordinateRelation", fields: [subordinateId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([subordinateId, organizationId])
  @@index([managerId, organizationId])
  @@map("user_hierarchies")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  used      Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ============================================================
// RBAC (GLOBAL)
// ============================================================

model Role {
  id                  String    @id @default(uuid())
  name                String    @unique
  label               String
  isSystem            Boolean   @default(false) @map("is_system")
  canAccessBackoffice Boolean   @default(false) @map("can_access_backoffice")
  canHaveSubordinates Boolean   @default(false) @map("can_have_subordinates")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  permissions          RolePermission[]
  members              Member[]
  categoryRoleAccesses CategoryRoleAccess[]

  @@map("roles")
}

model Module {
  id    String @id @default(uuid())
  name  String @unique // organizations, materials, categories
  label String

  permissions RolePermission[]

  @@map("modules")
}

enum Action {
  CREATE
  READ
  UPDATE
  DELETE
}

model RolePermission {
  id String @id @default(uuid())

  roleId   String @map("role_id")
  moduleId String @map("module_id")
  action   Action

  role   Role   @relation(fields: [roleId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])

  @@unique([roleId, moduleId, action])
  @@index([moduleId])
  @@map("role_permissions")
}

// ============================================================
// MULTI-TENANT
// ============================================================

model Member {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  roleId         String @map("role_id")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, userId])
  @@map("members")
}

model Organization {
  id                        String  @id @default(uuid())
  name                      String
  slug                      String  @unique
  domain                    String? @unique
  shouldAttachUsersByDomain Boolean @default(false) @map("should_attach_users_by_domain")
  avatarUrl                 String? @map("avatar_url")

  isActive  Boolean   @default(true) @map("is_active")
  isDeleted Boolean   @default(false) @map("is_deleted")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  members                Member[]
  categories             Category[]
  category_role_accesses CategoryRoleAccess[]
  userHierarchies        UserHierarchy[]

  @@map("organizations")
}

// ============================================================
// CATEGORY (MENU HIERÁRQUICO)
// ============================================================

model Category {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")

  name String
  slug String

  isActive Boolean @default(true) @map("is_active")
  order    Int

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  organization Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  categoryRoleAccesses CategoryRoleAccess[]

  @@unique([organizationId, slug])
  @@unique([organizationId, order])
  @@index([organizationId])
  @@index([parentId])
  @@index([organizationId, parentId])
  @@map("categories")
}

// ============================================================
// CONTROLE DE ACESSO ÀS CATEGORIAS
// ============================================================

model CategoryRoleAccess {
  id             String @id @default(uuid())
  categoryId     String @map("category_id")
  roleId         String @map("role_id")
  organizationId String @map("organization_id")

  category     Category     @relation(fields: [categoryId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([categoryId, roleId, organizationId])
  @@index([roleId, organizationId])
  @@index([categoryId])
  @@map("category_role_accesses")
}

// ============================================================
// LOG
// ============================================================

model Log {
  id        String   @id @default(uuid())
  level     LogLevel
  message   String   @map("message")
  context   Json?    @map("context")
  requestId String?  @map("request_id")
  path      String?  @map("path")
  method    String?  @map("method")
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("logs")
}

enum LogLevel {
  INFO
  WARNING
  ERROR
}
