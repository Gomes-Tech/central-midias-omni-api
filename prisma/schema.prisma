generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  name          String
  socialReason  String   @map("social_reason")
  taxIdentifier String   @unique @map("tax_identifier")
  phone         String   @map("phone")
  birthDate     DateTime @map("birth_date")
  email         String   @unique
  password      String
  isEmployee    Boolean  @default(false) @map("is_employee")
  isActive      Boolean  @default(true) @map("is_active")
  isDeleted     Boolean  @default(false) @map("is_deleted")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? @map("deleted_at")

  userCompanyAccesses UserCompanyAccess[]
  userRoles           UserRole[]
  userManager         UserManager?
  userLogins          UserLogins[]
  createdCategory     Category[]          @relation("UserCreatedCategory")
  updatedCategory     Category[]          @relation("UserUpdatedCategory")
  deletedCategory     Category[]          @relation("UserDeletedCategory")

  @@index([email])
  @@index([taxIdentifier])
  @@map("users")
}

model UserLogins {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("user_logins")
}

model UserManager {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_managers")
}

model UserRole {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @map("user_id")
  role      Roles    @relation(fields: [roleId], references: [id])
  roleId    String   @map("role_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roleId])
  @@map("user_roles")
}

model UserCompanyAccess {
  id        String  @id @default(uuid())
  user      User    @relation(fields: [userId], references: [id])
  userId    String  @map("user_id")
  company   Company @relation(fields: [companyId], references: [id])
  companyId String  @map("company_id")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_company_accesses")
}

model Company {
  id                  String              @id @default(uuid())
  name                String              @map("name")
  slug                String              @map("slug")
  logoUrl             String?             @map("logo_url")
  isActive            Boolean             @default(true) @map("is_active")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  userCompanyAccesses UserCompanyAccess[]

  @@map("companies")
}

model Roles {
  id                      String                   @id @default(uuid())
  label                   String
  role                    String                   @unique
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?                @map("deleted_at")
  userRoles               UserRole[]
  categoryRolePermissions CategoryRolePermission[]

  @@map("roles")
}

model Category {
  id       String  @id @default(cuid())
  name     String  @unique
  slug     String  @unique
  isActive Boolean @default(true) @map("is_active")
  order    Int     @unique

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  createdBy   User     @relation("UserCreatedCategory", fields: [createdById], references: [id])
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy   User?    @relation("UserUpdatedCategory", fields: [updatedById], references: [id])
  updatedById String?  @map("updated_by")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  deletedBy   User?    @relation("UserDeletedCategory", fields: [deletedById], references: [id])
  deletedById String?  @map("deleted_by")

  categoryRolePermissions CategoryRolePermission[]

  @@map("categories")
}

model CategoryRolePermission {
  id String @id @default(uuid())

  roleId     String @map("role_id")
  categoryId String @map("category_id")

  role     Roles    @relation(fields: [roleId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())

  @@unique([roleId, categoryId])
  @@index([roleId])
  @@index([categoryId])
  @@map("category_role_permissions")
}

