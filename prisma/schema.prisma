generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  taxIdentifier String    @unique @map("tax_identifier")
  phone         String?   @map("phone")
  socialReason  String?   @map("social_reason")
  avatarKey     String?   @map("avatar_key")
  birthDate     DateTime? @map("birth_date")
  admissionDate DateTime? @map("admission_date")
  isFirstAccess Boolean   @default(true) @map("is_first_access")
  isActive      Boolean   @default(true) @map("is_active")
  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  globalRoleId String? @map("global_role_id")
  globalRole   Role?   @relation(fields: [globalRoleId], references: [id])

  managedUsers        UserHierarchy[]          @relation("ManagerRelation")
  managerOf           UserHierarchy[]          @relation("SubordinateRelation")
  members             Member[]
  materialAcceptances MaterialAcceptance[]
  materialDownloads   MaterialDownload[]
  platformLogin       UserPlatformLogin?
  platformLoginEvents UserPlatformLoginEvent[]

  @@index([email])
  @@map("users")
}

model UserPlatformLogin {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  lastLoginAt DateTime @default(now()) @map("last_login_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastLoginAt])
  @@map("user_platform_logins")
}

model UserPlatformLoginEvent {
  id      String   @id @default(uuid())
  userId  String   @map("user_id")
  loginAt DateTime @default(now()) @map("login_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loginAt])
  @@map("user_platform_login_events")
}

model UserHierarchy {
  id String @id @default(uuid())

  managerId      String @map("manager_id")
  subordinateId  String @map("subordinate_id")
  organizationId String @map("organization_id")

  manager      User         @relation("ManagerRelation", fields: [managerId], references: [id])
  subordinate  User         @relation("SubordinateRelation", fields: [subordinateId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([subordinateId, organizationId])
  @@index([managerId, organizationId])
  @@map("user_hierarchies")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  used      Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ============================================================
// RBAC (GLOBAL)
// ============================================================

model Role {
  id                  String    @id @default(uuid())
  name                String    @unique
  label               String
  isSystem            Boolean   @default(false) @map("is_system")
  canAccessBackoffice Boolean   @default(false) @map("can_access_backoffice")
  canHaveSubordinates Boolean   @default(false) @map("can_have_subordinates")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  permissions          RolePermission[]
  members              Member[]
  categoryRoleAccesses CategoryRoleAccess[]
  users                User[]

  @@map("roles")
}

model Module {
  id    String @id @default(uuid())
  name  String @unique // organizations, materials, categories
  label String

  permissions RolePermission[]

  @@map("modules")
}

enum Action {
  CREATE
  READ
  UPDATE
  DELETE
}

model RolePermission {
  id String @id @default(uuid())

  roleId   String @map("role_id")
  moduleId String @map("module_id")
  action   Action

  role   Role   @relation(fields: [roleId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])

  @@unique([roleId, moduleId, action])
  @@index([moduleId])
  @@map("role_permissions")
}

// ============================================================
// MULTI-TENANT
// ============================================================

model Member {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  roleId         String @map("role_id")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, userId])
  @@map("members")
}

model Organization {
  id                        String  @id @default(uuid())
  name                      String
  slug                      String  @unique
  domain                    String? @unique
  shouldAttachUsersByDomain Boolean @default(false) @map("should_attach_users_by_domain")
  avatarKey                 String? @map("avatar_key")

  isActive  Boolean   @default(true) @map("is_active")
  isDeleted Boolean   @default(false) @map("is_deleted")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  members                Member[]
  categories             Category[]
  banners                Banner[]
  socialHighlights       SocialHighlight[]
  tags                   Tag[]
  faqs                   Faq[]
  faqItems               FaqItem[]
  category_role_accesses CategoryRoleAccess[]
  userHierarchies        UserHierarchy[]

  @@map("organizations")
}

// ============================================================
// CATEGORY (MENU HIERÁRQUICO)
// ============================================================

model Category {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")

  name     String
  slug     String
  slugPath String @map("slug_path")

  isActive Boolean @default(true) @map("is_active")
  order    Int

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  organization Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  categoryRoleAccesses CategoryRoleAccess[]
  materials            Material[]

  @@unique([organizationId, slugPath])
  @@unique([organizationId, parentId, slug])
  @@unique([organizationId, parentId, order])
  @@index([organizationId])
  @@index([parentId])
  @@index([organizationId, parentId])
  @@map("categories")
}

// ============================================================
// CONTROLE DE ACESSO ÀS CATEGORIAS
// ============================================================

model CategoryRoleAccess {
  id             String @id @default(uuid())
  categoryId     String @map("category_id")
  roleId         String @map("role_id")
  organizationId String @map("organization_id")

  category     Category     @relation(fields: [categoryId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([categoryId, roleId, organizationId])
  @@index([roleId, organizationId])
  @@index([categoryId])
  @@map("category_role_accesses")
}

model Banner {
  id              String    @id @default(cuid())
  organizationId  String    @map("organization_id")
  mobileImageKey  String    @map("mobile_image_key")
  desktopImageKey String    @map("desktop_image_key")
  name            String
  link            String?
  order           Int
  isActive        Boolean   @default(true) @map("is_active")
  initialDate     DateTime? @map("initial_date")
  finishDate      DateTime? @map("finish_date")

  isDeleted    Boolean      @default(false) @map("is_deleted")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("banners")
}

model SocialHighlight {
  id              String    @id @default(cuid())
  organizationId  String    @map("organization_id")
  mobileImageKey  String    @map("mobile_image_key")
  desktopImageKey String    @map("desktop_image_key")
  name            String
  link            String?
  order           Int
  isActive        Boolean   @default(true) @map("is_active")
  initialDate     DateTime? @map("initial_date")
  finishDate      DateTime? @map("finish_date")

  isDeleted    Boolean      @default(false) @map("is_deleted")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("social_highlights")
}

// ============================================================
// FAQ
// ============================================================

model Faq {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  name           String
  order          Int
  isActive       Boolean @default(true) @map("is_active")

  isDeleted Boolean   @default(false) @map("is_deleted")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  items        FaqItem[]
  detail       FaqDetail?

  @@index([organizationId])
  @@map("faqs")
}

model FaqItem {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  faqId          String @map("faq_id")
  question       String
  answer         String
  order          Int

  isDeleted Boolean   @default(false) @map("is_deleted")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  faq          Faq          @relation(fields: [faqId], references: [id])

  @@index([organizationId])
  @@index([faqId])
  @@map("faq_items")
}

model FaqDetail {
  id                       String  @id @default(uuid())
  faqId                    String  @unique @map("faq_id")
  imageKey                 String? @map("image_key")
  description              String?
  phonePrimary             String? @map("phone_primary")
  phonePrimaryLabel        String? @map("phone_primary_label")
  phonePrimaryIsWhatsapp   Boolean @default(false) @map("phone_primary_is_whatsapp")
  phoneSecondary           String? @map("phone_secondary")
  phoneSecondaryLabel      String? @map("phone_secondary_label")
  phoneSecondaryIsWhatsapp Boolean @default(false) @map("phone_secondary_is_whatsapp")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  faq Faq @relation(fields: [faqId], references: [id])

  @@map("faq_details")
}

// ATENÇÃO!
// Material está fora do padrão de soft delete. Corrigir para deletedAt e isDeleted, e ajustar queries para considerar ambos os campos.
model Material {
  id          String  @id @default(uuid())
  name        String
  description String?

  requiresAcceptance Boolean @default(false) @map("requires_acceptance")
  hasExternalLink    Boolean @default(false) @map("has_external_link")
  externalLink       String? @map("external_link")

  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  deletedAt           DateTime?            @map("deleted_at")
  materialFiles       MaterialFile[]
  categoryId          String               @map("category_id")
  category            Category             @relation(fields: [categoryId], references: [id])
  tags                Tag[]                @relation("MaterialTag")
  materialAcceptances MaterialAcceptance[]
  materialViews       MaterialView[]
  materialDownloads   MaterialDownload[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@map("materials")
}

model MaterialAcceptance {
  id         String   @id @default(uuid())
  materialId String   @map("material_id")
  userId     String   @map("user_id")
  accepted   Boolean  @default(true)
  acceptedAt DateTime @default(now()) @map("accepted_at")
  createdAt  DateTime @default(now()) @map("created_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([materialId, userId])
  @@index([materialId])
  @@index([userId])
  @@map("material_acceptances")
}

model MaterialView {
  id         String   @id @default(uuid())
  materialId String   @map("material_id")
  viewedAt   DateTime @default(now()) @map("viewed_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId])
  @@index([viewedAt])
  @@map("material_views")
}

model MaterialDownload {
  id           String   @id @default(uuid())
  materialId   String   @map("material_id")
  userId       String   @map("user_id")
  downloadedAt DateTime @default(now()) @map("downloaded_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([materialId])
  @@index([userId])
  @@index([downloadedAt])
  @@map("material_downloads")
}

model MaterialFile {
  id         String @id @default(uuid())
  materialId String @map("material_id")
  imageKey   String @map("image_key")
  mimeType   String @map("mime_type")
  size       Int    @map("size")

  material Material @relation(fields: [materialId], references: [id])

  @@map("material_files")
}

model Tag {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  name           String

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  organization Organization @relation(fields: [organizationId], references: [id])
  material     Material[]   @relation("MaterialTag")
  tagSearches  TagSearch[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("tags")
}

model TagSearch {
  id        String   @id @default(uuid())
  term      String
  search    String
  tagId     String   @map("tag_id")
  tag       Tag      @relation(fields: [tagId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tagId])
  @@index([term])
  @@index([search])
  @@map("tag_searches")
}

// ============================================================
// LOG
// ============================================================

model Log {
  id        String   @id @default(uuid())
  level     LogLevel
  message   String   @map("message")
  context   Json?    @map("context")
  requestId String?  @map("request_id")
  path      String?  @map("path")
  method    String?  @map("method")
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("logs")
}

enum LogLevel {
  INFO
  WARNING
  ERROR
}

model SeedStatus {
  id         String   @id @default(cuid())
  executedAt DateTime @default(now()) @map("executed_at")

  @@map("seed_status")
}
